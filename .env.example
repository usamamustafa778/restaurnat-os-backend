# RestaurantOS Backend – required environment variables
# Copy to .env and set values. On production (e.g. Render), set these in the dashboard.

MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/...
PORT=5000
JWT_SECRET=your_jwt_secret

# Required for image uploads (profile avatar, hero slides, menu items, etc.)
# Option A: three separate vars (from https://console.cloudinary.com → Dashboard / API Keys)
CLOUDINARY_CLOUD_NAME=dkiq8utsd
CLOUDINARY_API_KEY=236443426926736
CLOUDINARY_API_SECRET=t7ANJmsGHsGTQKK_p9suvVDLsDo
CLOUDINARY_URL=cloudinary://236443426926736:t7ANJmsGHsGTQKK_p9suvVDLsDo@dkiq8utsd

# Option B: single URL (format: cloudinary://api_key:api_secret@cloud_name)
# CLOUDINARY_URL=cloudinary://236443426926736:your_api_secret@dkiq8utsd

# Email/SMTP — required for storefront (and other) OTP emails. Without EMAIL_USER + EMAIL_PASS,
# OTPs are only logged in the API console; the storefront may show a dev code in the UI when NODE_ENV is not production.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Use the same noreply mailbox for tenant verification and storefront customer OTP (see utils/email.js).
EMAIL_USER=noreply@eatsdesk.com
EMAIL_PASS=your-smtp-password-or-app-password
EMAIL_FROM="Eats Desk <noreply@eatsdesk.com>"
# Optional: disable devOtp in API when email fails (default allows devOtp outside production)
# STOREFRONT_DEV_OTP_RESPONSE=0
# Optional (insecure): force devOtp even in production — do not use on a live site
# STOREFRONT_DEV_OTP_RESPONSE=1

# Dashboard login / verify-email: when SMTP is not configured or send fails, API may return devOtp in JSON (non-production).
# AUTH_DEV_OTP_RESPONSE=0   # never include devOtp
# AUTH_DEV_OTP_RESPONSE=1   # include devOtp even in production (insecure)
